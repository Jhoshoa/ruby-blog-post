<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Blog Posts" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Blog Posts">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="h-full">
    <div class="min-h-full">
      <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center">
              <div class="shrink-0">
                <%= link_to posts_path, class: "text-xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors" do %>
                  Blog Posts
                <% end %>
              </div>
              <div class="hidden md:block">
                <div class="ml-10 flex items-baseline space-x-4">
                  <%= link_to "All Posts", posts_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-100 transition-colors #{request.path == posts_path ? 'bg-gray-100 text-indigo-600' : ''}" %>
                  <%= link_to "Categories", categories_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-100 transition-colors #{request.path.start_with?('/categories') ? 'bg-gray-100 text-indigo-600' : ''}" %>
                  <% if user_signed_in? %>
                    <%= link_to "New Post", new_post_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-100 transition-colors #{request.path == new_post_path ? 'bg-gray-100 text-indigo-600' : ''}" %>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="hidden md:block">
              <div class="flex items-center space-x-4">
                <% if user_signed_in? %>
                  <span class="text-sm text-gray-600">Hi, <span class="font-medium text-gray-900"><%= current_user.name %></span></span>
                  <%= button_to "Sign out", logout_path, method: :delete, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-100 transition-colors" %>
                <% else %>
                  <%= link_to "Sign in", sign_in_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-100 transition-colors" %>
                  <%= link_to "Sign up", sign_up_path, class: "rounded-md bg-indigo-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </nav>

      <% if notice.present? %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-lg bg-green-50 p-4 ring-1 ring-inset ring-green-600/20">
            <div class="flex">
              <div class="shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="ml-3 text-sm font-medium text-green-800"><%= notice %></p>
            </div>
          </div>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-lg bg-red-50 p-4 ring-1 ring-inset ring-red-400/50">
            <div class="flex">
              <div class="shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="ml-3 text-sm font-medium text-red-800"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>

      <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
