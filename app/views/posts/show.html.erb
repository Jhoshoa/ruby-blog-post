<div class="mb-6">
  <%= link_to posts_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>
    <svg class="mr-1 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
    </svg>
    Back to Posts
  <% end %>
</div>

<article class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-gray-950/5">
  <div class="flex items-center gap-3 mb-4">
    <h1 class="text-3xl font-bold text-gray-900"><%= @post.title %></h1>
    <% if @post.published? %>
      <span class="inline-flex items-center rounded-full bg-green-50 px-2.5 py-0.5 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">Published</span>
    <% else %>
      <span class="inline-flex items-center rounded-full bg-yellow-50 px-2.5 py-0.5 text-xs font-medium text-yellow-700 ring-1 ring-inset ring-yellow-600/20">Draft</span>
    <% end %>
  </div>

  <p class="text-sm text-gray-500 mb-4">
    By <span class="font-medium text-gray-700"><%= @post.user.name %></span>
    · <%= time_ago_in_words(@post.created_at) %> ago
  </p>

  <div class="mb-4">
    <% if @post.category.present? %>
      <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20"><%= @post.category_name %></span>
    <% end %>
  </div>

  <% if @post.image.attached? %>
    <div class="mb-6">
      <%= image_tag @post.image, class: "w-full max-h-96 rounded-lg object-cover ring-1 ring-gray-200" %>
    </div>
  <% end %>

  <div class="prose prose-gray max-w-none mb-8">
    <p class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @post.body %></p>
  </div>

  <% if user_signed_in? && current_user == @post.user %>
    <div class="border-t border-gray-100 pt-6 flex items-center gap-4">
      <%= link_to "Edit", edit_post_path(@post), class: "inline-flex items-center rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors" %>
      <%= button_to "Delete", @post, method: :delete, data: { confirm: "Are you sure you want to delete this post?" }, class: "inline-flex items-center rounded-md bg-red-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 transition-colors" %>
    </div>
  <% end %>
</article>

<section class="mt-8 rounded-xl bg-white p-8 shadow-sm ring-1 ring-gray-950/5">
  <h2 class="text-xl font-bold text-gray-900 mb-6">
    Comments (<%= @post.comments.size %>)
  </h2>

  <% if user_signed_in? %>
    <%= form_with(model: [@post, Comment.new], class: "mb-8") do |f| %>
      <% if Comment.new.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 ring-1 ring-inset ring-red-400/50 mb-4">
          <div class="flex">
            <div class="shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
            </div>
            <p class="ml-3 text-sm text-red-700">Comment could not be saved.</p>
          </div>
        </div>
      <% end %>
      <div>
        <%= f.text_area :body, rows: 3, placeholder: "Write a comment...",
              class: "block w-full rounded-md border-0 py-1.5 px-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-shadow",
              required: true %>
      </div>
      <div class="mt-3 flex justify-end">
        <%= f.submit "Post Comment", class: "rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-sm text-gray-500 mb-8">
      <%= link_to "Sign in", sign_in_path, class: "text-indigo-600 font-medium hover:text-indigo-500" %> to leave a comment.
    </p>
  <% end %>

  <div id="comments_list" class="divide-y divide-gray-100">
    <% if @post.comments.any? %>
      <%= render partial: "comments/comment", collection: @post.comments.recent, as: :comment %>
    <% else %>
      <p class="py-4 text-sm text-gray-500">No comments yet. Be the first to comment!</p>
    <% end %>
  </div>
</section>
