<%= form_with model: post, class: "space-y-6", html: { multipart: true } do |form| %>

  <% if post.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 ring-1 ring-inset ring-red-400/50">
      <div class="flex">
        <div class="shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-semibold text-red-800">
            <%= pluralize(post.errors.count, "error") %> stopped this post from being saved:
          </h3>
          <ul class="mt-2 list-disc list-inside text-sm text-red-700">
            <% post.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium leading-6 text-gray-900" %>
    <div class="mt-2">
      <%= form.text_field :title,
            class: "block w-full rounded-md border-0 py-1.5 px-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-shadow",
            placeholder: "Enter post title" %>
    </div>
  </div>

  <div>
    <%= form.label :body, class: "block text-sm font-medium leading-6 text-gray-900" %>
    <div class="mt-2">
      <%= form.text_area :body, rows: 8,
            class: "block w-full rounded-md border-0 py-1.5 px-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-shadow",
            placeholder: "Write your post content here..." %>
    </div>
  </div>

  <div>
    <%= form.label :category, "Category", class: "block text-sm font-medium leading-6 text-gray-900" %>
    <p class="mt-1 text-xs text-gray-500">Select a category for this post.</p>
    <div class="mt-3" data-controller="category-selector">
      <div class="relative">
        <input type="text"
               data-category-selector-target="search"
               data-action="input->category-selector#search focus->category-selector#open"
               placeholder="Search categories..."
               autocomplete="off"
               class="block w-full rounded-md border-0 py-1.5 px-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-shadow" />
        <div data-category-selector-target="dropdown"
             class="absolute z-10 mt-1 max-h-60 w-full overflow-auto rounded-lg bg-white shadow-lg ring-1 ring-gray-200 hidden">
          <% Post::CATEGORIES.each do |name, value| %>
            <div data-category-selector-target="option"
                 data-value="<%= value %>"
                 data-name="<%= name %>"
                 data-action="click->category-selector#select"
                 class="cursor-pointer px-3 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-colors">
              <%= name %>
            </div>
          <% end %>
        </div>
      </div>
      <div data-category-selector-target="chips" class="mt-2 flex flex-wrap gap-1.5">
        <% if post.category.present? %>
          <span class="inline-flex items-center gap-1 rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20">
            <%= post.category_name %>
            <button type="button" data-action="click->category-selector#clear" class="ml-0.5 rounded-full p-0.5 hover:bg-indigo-100 transition-colors">
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>
            </button>
          </span>
        <% end %>
      </div>
      <%= form.hidden_field :category, data: { category_selector_target: "input" } %>
    </div>
  </div>

  <div class="flex items-center gap-x-3">
    <%= form.check_box :published, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
    <%= form.label :published, "Publish immediately", class: "block text-sm font-medium leading-6 text-gray-900" %>
  </div>

  <div>
    <%= form.label :image, "Cover image (optional)", class: "block text-sm font-medium leading-6 text-gray-900" %>
    <div class="mt-2 flex items-center gap-x-4">
      <%= form.file_field :image,
            accept: "image/png,image/jpeg,image/webp,image/gif",
            class: "block w-full text-sm text-gray-900 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 file:cursor-pointer file:transition-colors" %>
    </div>
    <p class="mt-1 text-xs text-gray-500">PNG, JPG, WebP or GIF. Max 5MB.</p>
    <% if post.image.attached? %>
      <div class="mt-3">
        <p class="text-sm text-gray-600 mb-1">Current image:</p>
        <%= image_tag post.image, class: "h-32 w-auto rounded-lg object-cover ring-1 ring-gray-200" %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-x-4 pt-2">
    <%= form.submit class: "rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", posts_path, class: "text-sm font-semibold text-gray-700 hover:text-gray-600 transition-colors" %>
  </div>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const container = document.querySelector("[data-controller='category-selector']");
    if (!container) return;

    const search = container.querySelector("[data-category-selector-target='search']");
    const dropdown = container.querySelector("[data-category-selector-target='dropdown']");
    const input = container.querySelector("[data-category-selector-target='input']");
    const chips = container.querySelector("[data-category-selector-target='chips']");
    const options = container.querySelectorAll("[data-category-selector-target='option']");

    window.categorySelectorSearch = function() {
      const query = search.value.toLowerCase();
      let hasVisible = false;
      options.forEach(function(opt) {
        const match = opt.dataset.name.toLowerCase().includes(query);
        opt.style.display = match ? "" : "none";
        if (match) hasVisible = true;
      });
      dropdown.classList.toggle("hidden", !hasVisible);
    };

    window.categorySelectorSelect = function(e) {
      const option = e.target.closest("[data-value]");
      if (!option) return;
      input.value = option.dataset.value;
      search.value = "";
      dropdown.classList.add("hidden");
      renderChip(option.dataset.name, option.dataset.value);
    };

    window.categorySelectorClear = function() {
      input.value = "";
      search.value = "";
      chips.innerHTML = "";
    };

    window.categorySelectorOpen = function() {
      const query = search.value.toLowerCase();
      let hasVisible = false;
      options.forEach(function(opt) {
        const match = opt.dataset.name.toLowerCase().includes(query);
        if (match) hasVisible = true;
      });
      if (hasVisible) dropdown.classList.remove("hidden");
    };

    function renderChip(name, value) {
      chips.innerHTML = '<span class="inline-flex items-center gap-1 rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20">' +
        name +
        '<button type="button" onclick="categorySelectorClear()" class="ml-0.5 rounded-full p-0.5 hover:bg-indigo-100 transition-colors">' +
        '<svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>' +
        '</button></span>';
    }

    document.addEventListener("click", function(e) {
      if (!container.contains(e.target)) {
        dropdown.classList.add("hidden");
      }
    });
  });
</script>
