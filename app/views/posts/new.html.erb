<div class="mb-6">
  <%= link_to posts_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>
    <svg class="mr-1 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
    </svg>
    Back to Posts
  <% end %>
</div>

<div class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-gray-950/5">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Post</h1>
  <%= render "form", post: @post %>
</div>
